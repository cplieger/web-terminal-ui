{
  "name": "@cplieger/web-terminal-ui",
  "version": "0.1.0",
  "exports": {
    ".": "./src/index.ts",
    "./presets": "./src/presets.ts",
    "./presets/single": "./src/presets/single.ts",
    "./presets/touch": "./src/presets/touch.ts",
    "./presets/tabbed": "./src/presets/tabbed.ts",
    "./presets/agent-tabbed": "./src/presets/agent-tabbed.ts",
    "./features/clipboard": "./src/features/clipboard.ts",
    "./features/context-menu": "./src/features/context-menu.ts",
    "./features/scroll-to-bottom": "./src/features/scroll-to-bottom.ts",
    "./features/predictive-echo": "./src/features/predictive-echo.ts",
    "./features/connection-banner": "./src/features/connection-banner.ts",
    "./features/mobile-toolbar": "./src/features/mobile-toolbar.ts",
    "./features/tabs": "./src/features/tabs/index.ts",
    "./features/activity-monitor": "./src/features/activity-monitor.ts",
    "./features/animations": "./src/features/animations.ts"
  },
  "imports": {
    "@cplieger/web-terminal-engine": "jsr:@cplieger/web-terminal-engine@^3.0.0"
  },
  "publish": {
    "include": [
      "LICENSE",
      "README.md",
      "src/**/*.ts",
      "css/**/*.css",
      "css/MANIFEST",
      "css/MANIFEST.single",
      "css/MANIFEST.touch",
      "css/MANIFEST.tabbed",
      "scaffold/index.html"
    ],
    "exclude": ["src/**/*.test.ts", "src/fc-strict-setup.ts"]
  }
}
