# Component bundle for presetTouch() compositions (single + the mobile key
# toolbar). Library styles only — root-scoped, no page-level rules; the host
# page owns its own reset/fonts (vibekit's embedded panel serves exactly this).
# Files concatenate in declared order; the order IS the cascade.
00-tokens.css
01-scope.css
02-terminal.css
10-primitives.css
20-connection-banner.css
21-scroll-to-bottom.css
22-context-menu.css
23-toolbar.css
