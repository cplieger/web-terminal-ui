# Component bundle for presetTabbed() / presetAgentTabbed() compositions: the
# touch set plus tabs (strip + mobile switcher) and the animations feature's
# motion. Library styles only — root-scoped, no page-level rules. A full-page
# host serves the reference MANIFEST instead (this set + page.css).
# Files concatenate in declared order; the order IS the cascade.
00-tokens.css
01-scope.css
02-terminal.css
10-primitives.css
20-connection-banner.css
21-scroll-to-bottom.css
22-context-menu.css
23-toolbar.css
30-tabs.css
31-switcher.css
40-animations.css
