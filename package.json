{
  "name": "@cplieger/web-terminal-ui",
  "version": "0.1.0",
  "type": "module",
  "description": "Reference touch-first browser UI for @cplieger/web-terminal-engine: textarea input model, mobile key toolbar, context menu, IME, predictive echo, viewport/keyboard-inset handling, and CSS. One mount() call.",
  "license": "GPL-3.0-or-later",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "typecheck": "tsgo -p tsconfig.json",
    "typecheck:tests": "tsgo -p tsconfig.test.json",
    "test": "vitest --run",
    "test:watch": "vitest",
    "test:coverage": "vitest --run --coverage",
    "lint:eslint": "eslint .",
    "lint:prettier": "prettier --check .",
    "lint:fix": "eslint . --fix && prettier --write .",
    "lint:knip": "knip",
    "verify": "bash scripts/verify.sh"
  },
  "peerDependencies": {
    "@cplieger/web-terminal-engine": ">=1.2.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.9.4",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.6.0",
    "fast-check": "4.8.0",
    "happy-dom": "20.10.6",
    "html-validate": "11.5.3",
    "knip": "6.23.0",
    "prettier": "3.9.3",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cplieger/web-terminal-ui.git"
  },
  "files": [
    "src/",
    "css/",
    "scaffold/",
    "LICENSE",
    "README.md",
    "!src/**/*.test.ts",
    "!src/**/fc-strict-setup.ts"
  ]
}
